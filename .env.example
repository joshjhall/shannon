# Shannon development environment — non-secret config.
#
# Copy to .env and adjust. This file is committed as a template; .env itself is
# gitignored. Secrets go in .env.secrets (see .env.secrets.example), NOT here:
# Docker Compose exposes env_file values via `docker compose config`, which the
# Dev Containers extension logs.

# =============================================================================
# Container Environment
# =============================================================================
TZ=America/Chicago
ENVIRONMENT=development

# =============================================================================
# 1Password Secret Refs (OP_*_REF convention)
# =============================================================================
# Any OP_<NAME>_REF is resolved from 1Password → exports <NAME> at runtime.

# GitHub development token
OP_GITHUB_TOKEN_REF=op://Development/GitHub Development Token/credential

# Git identity (from 1Password)
OP_GIT_USER_NAME_REF=op://Development/Git Configuration/full name
OP_GIT_USER_EMAIL_REF=op://Development/Git Configuration/email

# SSH keys (separate auth and signing keys)
OP_GIT_AUTH_SSH_KEY_REF=op://Development/Git Authentication SSH Key/private key
OP_GIT_SIGNING_SSH_KEY_REF=op://Development/Git SSH Signing Key/private key

# Claude Code configuration on the Olympus network. Shannon sits IN FRONT of
# this base URL in production (Claude Code → shannon → Bifrost → Anthropic);
# in the devcontainer these configure Claude Code directly.
OP_ANTHROPIC_AUTH_TOKEN_REF=op://Development/Bifrost - claude-code-dev/credential
OP_ANTHROPIC_BASE_URL_REF=op://Development/Bifrost - claude-code-dev/base url
OP_ANTHROPIC_MODEL_REF=op://Development/Bifrost - claude-code-dev/default model

# Extra MCP servers to add (comma-separated). Kagi for research.
OP_KAGI_API_KEY_REF=op://Development/Kagi API Key/credential
CLAUDE_EXTRA_MCPS=kagi
