{
  "yaml": {
    "printWidth": 120
  },
  "json": {
    "indentWidth": 2,
    "lineWidth": 100
  },
  "excludes": [
    "CHANGELOG.md",
    "target/**",
    "node_modules/**",
    ".git/**",
    "/containers/",
    "**/*.lock"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ]
}
